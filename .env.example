# Postgres connection string
DATABASE_URL=postgresql://user:password@host:5432/invest

# Alpaca PAPER trading credentials (https://app.alpaca.markets/paper/dashboard)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Dashboard / API basic auth — API refuses to start without INVEST_PASS
INVEST_USER=invest
INVEST_PASS=

# Optional: news ingestion (https://finnhub.io)
FINNHUB_API_KEY=

# Optional: email digests (Gmail SMTP). Can also be set later from the
# dashboard Settings page, which takes precedence at runtime.
SMTP_USER=
SMTP_PASS=
DIGEST_TO=

# Optional: WhatsApp notification proxy (homelab-specific ATQ service)
ATQ_URL=http://localhost:8700
